# Copy to .env and fill in. Never commit real secrets.

# --- Required for core Slack + Claude ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
ANTHROPIC_API_KEY=

# Claude model (default claude-sonnet-4-6; claude-sonnet-4-20250514 was retired 2026-06-15)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Context-heavy commands (sales prep, weekly status, Granola, action items) use the commercial model:
# ANTHROPIC_COMMERCIAL_MODEL=claude-sonnet-4-6
# Future sovereign/local model (when configured): SOVEREIGN_MODEL=…
# Default route for light commands when sovereign is available: SUSAN_DEFAULT_MODEL_ROUTE=default|sovereign

# --- FrontierOne sovereign model (dogfooding on our own OVH-served model) ---
# When F1_MODEL_BASE_URL is set, light commands (doc, email, pr, …) use the sovereign
# model. Context-heavy commands (sales prep, weekly status, Granola, action items) always
# use Anthropic commercial models. ANTHROPIC_API_KEY is required for those flows.
# F1_MODEL_BASE_URL=https://model-a.frontierone.dev/v1
# F1_MODEL_API_KEY=        # bearer key for the model endpoint (LiteLLM master key)
# F1_MODEL_NAME=model-a

# --- Google (Docs, Gmail, Calendar, Drive metadata, action-item Sheets ledger) ---
# In GCP (same project as GOOGLE_CLIENT_ID): enable Google Docs, Drive, Sheets, Gmail, Calendar APIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_HOST/auth/google/callback

# Optional: single shared Google access token for ALL users (see SECURITY.md)
# GOOGLE_ACCESS_TOKEN=

# --- GitHub OAuth (per-user connect) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://YOUR_HOST/auth/github/callback

# Optional scope; add security_events for Dependabot in weekly status, e.g. repo security_events
# GITHUB_OAUTH_SCOPE=repo

# Optional: single PAT for ALL users (see SECURITY.md)
# GITHUB_TOKEN=

# --- Granola OAuth (per-user connect; `/susan granola` uses the REST API with the user's token) ---
# Register an OAuth redirect URL with Granola that matches this app (e.g. …/auth/granola/callback).
# If you only have PUBLIC_BASE_URL, Susan derives the callback automatically.
# Static client id/secret are not documented for end users on Granola MCP (dynamic registration); for a
# custom Slack app, obtain credentials from Granola or email hey@granola.so — see:
# https://docs.granola.ai/help-center/sharing/integrations/mcp
GRANOLA_CLIENT_ID=
GRANOLA_CLIENT_SECRET=
# MCP endpoint Susan will call to read meeting notes for the connected user.
GRANOLA_MCP_URL=
# Optional: override public REST API host (default https://public-api.granola.ai — see app/granola_summarize.py).
# GRANOLA_API_BASE=https://public-api.granola.ai
# Optional: derived from PUBLIC_BASE_URL if unset (e.g. https://YOUR_HOST/auth/granola/callback)
# GRANOLA_REDIRECT_URI=https://YOUR_HOST/auth/granola/callback
# Optional: override Granola OAuth endpoints if they move
# GRANOLA_AUTHORIZE_URL=https://api.granola.ai/oauth/authorize
# GRANOLA_TOKEN_URL=https://api.granola.ai/oauth/token
# Optional: OAuth scope(s) requested from Granola (space-separated)
# GRANOLA_OAUTH_SCOPE=
# Tags Susan considers "goal-relevant" when surfacing Granola notes (reserved for future use).
GRANOLA_GOAL_TAGS=planning,design review,interview,demo,onboarding
# How many days of Granola history `/susan granola` uses when you omit a date phrase (default 7).
GRANOLA_LOOKBACK_DAYS=7
# How many days `/susan actions` scans when you omit a date phrase (default 14).
# ACTION_ITEMS_LOOKBACK_DAYS=14
# Slack thread replies included in `/susan actions` (default on): caps below.
# ACTION_ITEMS_MAX_THREADS=80
# ACTION_ITEMS_MAX_THREAD_REPLIES=150
# Linked Google Docs: full text fetched for extraction (requires Google Docs API enabled).
# ACTION_ITEMS_MAX_GOOGLE_DOCS=8
# ACTION_ITEMS_GOOGLE_DOC_MAX_CHARS=8000
# ACTION_ITEMS_GRANOLA_MAX_CHARS=28000
# Set GRANOLA_SUMMARY_INCLUDE_TRANSCRIPT=true to include meeting transcripts in action items.
# Optional: use an existing spreadsheet instead of auto-creating on first `/susan actions`.
# ACTION_ITEMS_SPREADSHEET_ID=
# ACTION_ITEMS_SPREADSHEET_TITLE=Susan Action Items
# GRANOLA_SUMMARY_MAX_NOTES=12
# GRANOLA_SUMMARY_MAX_LIST_PAGES=5
# GRANOLA_SUMMARY_INCLUDE_TRANSCRIPT=false

# Sales call prep (`/susan prep me for a sales call with …`) — uses Claude Opus by default
# SALES_PREP_ANTHROPIC_MODEL=claude-opus-4-6
# Scans the connected user's accessible Google Drive for Docs/Slides with sales/GTM/F1-style names.
# Optional extra roots (folder IDs/URLs or file IDs/URLs) if you want to force-include paths:
# SALES_PREP_DRIVE_FOLDER_IDS=
# SALES_PREP_DRIVE_FILE_IDS=
# SALES_PREP_DRIVE_MAX_LIST=100
# SALES_PREP_GATHER_TIMEOUT_SECONDS=120
# SALES_PREP_TIMEOUT_SECONDS=480
# SALES_PREP_ANTHROPIC_TIMEOUT_SECONDS=300
# SALES_PREP_MAX_CONTEXT_CHARS=80000
# SALES_PREP_GRANOLA_MAX_LIST_PAGES=4
# SALES_PREP_MAX_SLIDES=8
# SALES_PREP_MAX_FOLDERS=8
# SALES_PREP_DRIVE_DEPTH=10
# SALES_PREP_MAX_DOCS=12
# SALES_PREP_DOC_MAX_CHARS=12000
# SALES_PREP_DRIVE_MAX_API_CALLS=80
# SALES_PREP_GRANOLA_LOOKBACK_DAYS=180
# SALES_PREP_GRANOLA_MAX_NOTES=8
# SALES_PREP_MAX_TOKENS=8192

# --- URLs Slack will open (OAuth links in chat) ---
PUBLIC_BASE_URL=https://YOUR_HOST

# Optional: separate secret for signing OAuth state (defaults to SLACK_SIGNING_SECRET)
# OAUTH_STATE_SECRET=
# OAUTH_STATE_TTL_SECONDS=86400

# --- Repo defaults / allowlists (strongly recommended for team deploys) ---
# GITHUB_REPO=myorg/myrepo
# GITHUB_REPOS=myorg/a,myorg/b
# GITHUB_ISSUES_REPO=
# GITHUB_ISSUES_REPOS=
# GITHUB_BASE_BRANCH=main

# --- Database (Railway: set DATABASE_URL; local default is SQLite under ./data/) ---
# Railway: in the Susan service, add a variable reference to Postgres → DATABASE_PRIVATE_URL
# and name it DATABASE_URL (private network, no SSL issues). Public proxy URLs also work
# after the Railway SSL fix in db.py; or set DATABASE_SSL=insecure if needed.
# DATABASE_URL=postgresql://...
# DATABASE_SSL=insecure
# SQLITE_PATH=./data/susan.db

# --- Optional behavior ---
# DEFAULT_EMAIL_TO=
# SLACK_USER_EMAIL_MAP=

# Weekly status: restrict who may use --no-approval / -no-approval
# SUSAN_WEEKLY_AUTO_POST_USER_IDS=U01234567,U07654321

# Scheduled jobs (`/susan schedule …`)
# SUSAN_SCHEDULE_TIMEZONE=America/Los_Angeles
# Default channel when a schedule omits `in …` (Susan #team-tech)
# SUSAN_DEFAULT_SCHEDULE_CHANNEL=C0ANY6ASRB5
# SUSAN_SCHEDULE_CHANNEL_ALIASES=team-tech:C0ANY6ASRB5

# Tech channel names (comma slugs) for GitHub-backed weekly status
# SUSAN_TECH_WEEKLY_CHANNEL_NAMES=team-tech,software,security

# Weekly status: post full update to Slack Canvas + short link in channel (default on)
# WEEKLY_STATUS_USE_CANVAS=true

# Caps and tuning (defaults are sane; see README)
# WEEKLY_STATUS_MAX_SLACK_MESSAGES=800
# WEEKLY_STATUS_MAX_SLACK_CHARS=120000
# WEEKLY_STATUS_MAX_TOKENS=8192
# WEEKLY_STATUS_ANTHROPIC_MODEL=claude-opus-4-6
# WEEKLY_DRIVE_MAX_FOLDERS=10
# WEEKLY_DRIVE_MAX_DEPTH=12
# WEEKLY_DRIVE_MAX_FILES_REPORTED=120
# WEEKLY_DRIVE_MAX_API_CALLS=100
# PR_SUMMARY_MAX_PARTICIPANT_FETCH=80
# ANTHROPIC_MAX_RETRIES=5
# ANTHROPIC_RETRY_DELAY_SECONDS=2
